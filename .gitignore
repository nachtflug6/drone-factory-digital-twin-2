# .gitignore
# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
ENV/
env/
.venv

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Testing
.pytest_cache/
.coverage
htmlcov/

# Data and logs (gitignore large files, keep structure)
data/logs/*.jsonl
data/logs/*.csv
data/logs/*.bin
data/embeddings/*.pkl
data/embeddings/*.npy

# Analysis notebooks (but version control notebook metadata)
analysis/notebooks/.ipynb_checkpoints/

# Docker / Containers
*.sif
*.img
.dockerignore

# SLURM outputs
simulation_*.log
simulation_*.err
slurm-*.out

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# Large output files
*.tar.gz
*.zip
.ipynb_checkpoints/

# Temporary files
*.tmp
*.temp
*backup*
